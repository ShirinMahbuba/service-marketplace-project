generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String          @id @default(cuid())
  name          String
  email         String          @unique
  role          String          @default("END_USER") // ADMIN, VENDOR, END_USER
  createdAt     DateTime        @default(now())
  vendorProfile VendorProfile?
  transactions  Transaction[]
}

model VendorProfile {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id])
  bio         String    @default("")
  phone       String    @default("")
  services    Service[]
  createdAt   DateTime  @default(now())
}

model Service {
  id              String        @id @default(cuid())
  vendorProfileId String
  vendorProfile   VendorProfile @relation(fields: [vendorProfileId], references: [id])
  name            String
  description     String
  price           Float
  category        String        // Cleaning, Plumbing, AC Repair, etc.
  isActive        Boolean       @default(true)
  transactions    Transaction[]
  createdAt       DateTime      @default(now())
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  serviceId   String
  service     Service  @relation(fields: [serviceId], references: [id])
  amount      Float
  status      String   @default("SUCCESS") // SUCCESS, FAILED, PENDING
  paymentMethod String @default("bKash")
  createdAt   DateTime @default(now())
}
